.streamlit/secrets.toml

# --- Environment Variables ---
.env
.env.*

# --- InsightFace Model Cache ---
models/
.insightface/
*.onnx

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Temp uploads ---
temp_uploads/

# --- Logs ---
*.log

# --- Videos for testing ---
*.mp4
*.avi
*.mov